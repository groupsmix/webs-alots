# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# R-06: Do NOT commit .env.production or any production secrets.
# Use `wrangler secret put` for production secrets. NEVER add
# !.env.production here — it could accidentally expose secrets.
# For local development, use .env.local (already ignored by .env*)

# typescript
*.tsbuildinfo
next-env.d.ts

# client tracker (private)
/clients/

# Generated API docs (rebuild with: npm run docs:generate)
/docs/api

# Database dumps
full_backup.sql
lint.txt
lint.txt
*.log
