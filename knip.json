{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/app/**/page.tsx",
    "src/app/**/layout.tsx",
    "src/app/**/route.ts",
    "src/app/**/loading.tsx",
    "src/app/**/error.tsx",
    "src/app/**/not-found.tsx",
    "sentry.*.config.ts",
    "scripts/**/*.{ts,mjs}",
    "supabase/functions/*/index.ts",
    "worker-cron-handler.ts",
    "open-next.config.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "scripts/**/*.{ts,mjs}",
    "supabase/functions/**/*.ts",
    "e2e/**/*.ts",
    "*.config.{ts,mjs}"
  ],
  "ignore": ["src/lib/types/database.ts"],
  "ignoreBinaries": ["supabase"],
  "ignoreUnresolved": [".open-next/worker.js"],
  "ignoreDependencies": [
    "eslint-plugin-jsx-a11y",
    "tailwindcss",
    "eslint-plugin-react-hooks",
    "tw-animate-css",
    "shadcn"
  ]
}
