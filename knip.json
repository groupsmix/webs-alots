{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/app/**/page.tsx",
    "src/app/**/layout.tsx",
    "src/app/**/route.ts",
    "src/app/**/loading.tsx",
    "src/app/**/error.tsx",
    "src/app/**/not-found.tsx",
    "sentry.*.config.ts",
    "scripts/**/*.{ts,mjs}",
    "supabase/functions/*/index.ts",
    "evals/**/*.ts",
    "open-next.config.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "scripts/**/*.{ts,mjs}",
    "supabase/functions/**/*.ts",
    "e2e/**/*.ts",
    "evals/**/*.ts",
    "*.config.{ts,mjs}"
  ],
  "ignore": ["src/lib/types/database.ts"],
  "ignoreBinaries": ["supabase"],
  "ignoreUnresolved": [],
  "ignoreDependencies": [
    "eslint-plugin-jsx-a11y",
    "tailwindcss",
    "tw-animate-css",
    "shadcn",
    "@anthropic-ai/sdk"
  ],
  "rules": {
    "files": "warn",
    "exports": "warn",
    "nsExports": "warn",
    "types": "warn",
    "nsTypes": "warn",
    "enumMembers": "warn",
    "duplicates": "warn",
    "unresolved": "warn"
  }
}
