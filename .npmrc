; CopilotKit 1.59 declares @anthropic-ai/sdk@^0.57 as a peerOptional dependency,
; while we deliberately pin @anthropic-ai/sdk@^0.101. The two are wire-compatible
; for the constructor/messages surface we use, so we tell npm to keep its npm@6
; behavior and not refuse the install on this peer mismatch.
legacy-peer-deps=true
