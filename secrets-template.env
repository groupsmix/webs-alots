# ============================================================
# Oltigo Platform — Secrets Template
# ============================================================
# Copy this file to .env and fill in your real values.
# Used by scripts/recover.sh for one-click disaster recovery.
#
# NEVER commit the filled-in .env file to version control.
# ============================================================

# === SUPABASE (Required) ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SECURITY: Use dynamic secret vending in production
# Format: vault://secret/supabase/service-role-key or kms://key-id/supabase-service-role
# For disaster recovery, use plaintext key from Supabase Dashboard > Project Settings > API
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=your-project-ref
# Direct database connection URL (for pg_dump backups)
SUPABASE_DB_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# === CLOUDFLARE (Required for deploy) ===
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# === CLOUDFLARE R2 STORAGE ===
# SECURITY: Use OIDC-based ephemeral credentials in production
# For CI/CD: Use GitHub OIDC token exchange (see .github/workflows/deploy.yml)
# For disaster recovery: Use access keys from Cloudflare Dashboard
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=webs-alots-uploads
R2_PUBLIC_URL=https://uploads.oltigo.com
# REQUIRED in production: HMAC secret for signed-URL authorization and
# upload-key filename hashing.
# SECURITY: Use Vault/KMS in production
# Format: vault://secret/r2/signed-url-secret or kms://key-id/r2-signed-url
# For disaster recovery, generate with `openssl rand -hex 32`.
# Rotation: docs/SOP-SECRET-ROTATION.md §8 (automated 90-day cadence)
R2_SIGNED_URL_SECRET=
# Backup bucket (separate from uploads)
R2_BACKUP_BUCKET=webs-alots-backups

# === PAYMENTS — Stripe ===
# SECURITY: Use Vault/KMS in production
# Format: vault://secret/stripe/secret-key or kms://key-id/stripe-secret
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === PAYMENTS — CMI (Morocco) ===
# SECURITY: Use Vault/KMS in production
# Format: vault://secret/cmi/secret-key or kms://key-id/cmi-secret
CMI_MERCHANT_ID=
CMI_SECRET_KEY=
CMI_GATEWAY_URL=

# === WHATSAPP BUSINESS API (Meta Cloud API) ===
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
META_APP_SECRET=

# === EMAIL ===
RESEND_API_KEY=

# === PHI ENCRYPTION ===
# AES-256-GCM key for patient file encryption (64 hex chars)
# SECURITY: Use Vault/KMS in production with automated 90-day rotation
# Format: vault://secret/phi/encryption-key or kms://key-id/phi-encryption
# For disaster recovery, generate with: openssl rand -hex 32
# Rotation: Automated via scripts/rotate-phi-key.ts (see docs/SOP-SECRET-ROTATION.md)
PHI_ENCRYPTION_KEY=

# === BACKUP ENCRYPTION (Optional but recommended) ===
# Symmetric key for encrypting database backups before R2 upload
# Generate with: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=

# === AI (Optional) ===
# SECURITY: Use Vault/KMS in production
# Format: vault://secret/openai/api-key or kms://key-id/openai-key
OPENAI_API_KEY=
CLOUDFLARE_AI_API_TOKEN=

# === SENTRY (Optional) ===
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# === CRON AUTHENTICATION ===
# SECURITY: Use Vault/KMS in production
# Format: vault://secret/cron/secret or kms://key-id/cron-secret
# For disaster recovery, generate with: openssl rand -hex 32
CRON_SECRET=

# === PROFILE HEADER HMAC ===
# Signs x-auth-profile-* headers between middleware and withAuth.
# MUST be distinct from CRON_SECRET (audit R-02).
# SECURITY: Use Vault/KMS in production
# Format: vault://secret/profile/hmac-key or kms://key-id/profile-hmac
# For disaster recovery, generate with: openssl rand -hex 32
PROFILE_HEADER_HMAC_KEY=

# === BOOKING TOKEN SECRET ===
# SECURITY: Use Vault/KMS in production
# Format: vault://secret/booking/token-secret or kms://key-id/booking-token
# For disaster recovery, generate with: openssl rand -hex 32
BOOKING_TOKEN_SECRET=

# === SITE URL ===
NEXT_PUBLIC_SITE_URL=https://oltigo.com
ROOT_DOMAIN=oltigo.com

# === APP URL (for health check verification) ===
APP_URL=https://oltigo.com
