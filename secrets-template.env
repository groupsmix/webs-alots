# ============================================================
# Oltigo Platform — Secrets Template
# ============================================================
# Copy this file to .env and fill in your real values.
# Used by scripts/recover.sh for one-click disaster recovery.
#
# NEVER commit the filled-in .env file to version control.
# ============================================================

# === SUPABASE (Required) ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=your-project-ref
# Direct database connection URL (for pg_dump backups)
SUPABASE_DB_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# === CLOUDFLARE (Required for deploy) ===
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# === CLOUDFLARE R2 STORAGE ===
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=webs-alots-uploads
R2_PUBLIC_URL=https://uploads.oltigo.com
# REQUIRED in production: HMAC secret for signed-URL authorization and
# upload-key filename hashing. Generate with `openssl rand -hex 32`.
# Rotation: docs/SOP-SECRET-ROTATION.md §8
R2_SIGNED_URL_SECRET=
# Backup bucket (separate from uploads)
R2_BACKUP_BUCKET=webs-alots-backups

# === PAYMENTS — Stripe ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === PAYMENTS — CMI (Morocco) ===
CMI_MERCHANT_ID=
CMI_SECRET_KEY=
CMI_GATEWAY_URL=

# === WHATSAPP BUSINESS API (Meta Cloud API) ===
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
META_APP_SECRET=

# === EMAIL ===
RESEND_API_KEY=

# === PHI ENCRYPTION ===
# AES-256-GCM key for patient file encryption (64 hex chars)
# Generate with: openssl rand -hex 32
PHI_ENCRYPTION_KEY=

# === BACKUP ENCRYPTION (Optional but recommended) ===
# Symmetric key for encrypting database backups before R2 upload
# Generate with: openssl rand -hex 32
BACKUP_ENCRYPTION_KEY=

# === AI (Optional) ===
# OpenAI API key for prescription, patient-summary, drug-check, auto-suggest,
# manager, and advanced chatbot endpoints.
# DPA: OpenAI API terms prohibit training on API data. See docs/data-residency.md.
OPENAI_API_KEY=
# Base URL for the OpenAI-compatible API. MUST be on the egress allowlist
# defined in src/lib/ai/openai.ts. Default: https://api.openai.com/v1
# Allowed: api.openai.com, oai.azure.com, gateway.ai.cloudflare.com, api.cloudflare.com
# OPENAI_BASE_URL=https://api.openai.com/v1
# Model identifier. Pin to a dated snapshot to prevent silent rotation.
# Default: gpt-4o-mini-2024-07-18
# OPENAI_MODEL=gpt-4o-mini-2024-07-18
# Comma-separated list of additional HTTPS origins to allow for OPENAI_BASE_URL.
# Only https:// prefixes are accepted. Example: https://my-proxy.example.com
# OPENAI_BASE_URL_ALLOWLIST=
CLOUDFLARE_AI_API_TOKEN=

# === SENTRY (Optional) ===
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# === CRON AUTHENTICATION ===
# Generate with: openssl rand -hex 32
CRON_SECRET=

# === PROFILE HEADER HMAC ===
# Signs x-auth-profile-* headers between middleware and withAuth.
# MUST be distinct from CRON_SECRET (audit R-02).
# Generate with: openssl rand -hex 32
PROFILE_HEADER_HMAC_KEY=

# === BOOKING TOKEN SECRET ===
# Generate with: openssl rand -hex 32
BOOKING_TOKEN_SECRET=

# === SITE URL ===
NEXT_PUBLIC_SITE_URL=https://oltigo.com
ROOT_DOMAIN=oltigo.com

# === APP URL (for health check verification) ===
APP_URL=https://oltigo.com
