# ── Required ─ Supabase ──────────────────────────────────
# In production, use the pooler URL (https://xxx.pooler.supabase.com)
# instead of the direct URL for proper connection pooling on edge runtimes.
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Required ─ Auth ──────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-byte-hex-string
# Development fallback only — do NOT rely on this in production.
# In production, use database-managed admin users instead.
ADMIN_PASSWORD=change-me-fallback-admin-password

# ── Required (production) ─ Internal API ─────────────────
# Shared secret for internal service-to-service communication (middleware ↔ resolve-site)
INTERNAL_API_TOKEN=change-me-to-a-random-64-byte-hex-string

# ── Required (production) ─ Cron jobs ────────────────────
CRON_SECRET=change-me-to-a-random-string

# ── Required (production) ─ Cron host ────────────────────
# Canonical base URL the scheduled Worker POSTs cron jobs to.
# Set this to your primary site domain (e.g. https://wristnerd.xyz).
# Without this the Worker will log an error and skip all scheduled jobs.
CRON_HOST=https://your-primary-domain.example.com

# ── Optional ─ Email (Resend) ────────────────────────────
RESEND_API_KEY=
NEWSLETTER_FROM_EMAIL=

# ── Optional ─ Image storage (Cloudflare R2, S3-API) ─────
# Used by lib/r2.ts to generate presigned upload URLs.
# The browser uploads directly to R2 — no Worker binding needed.
# In production, set these as runtime secrets via `wrangler secret put`.
# See docs/cloudflare-r2-images.md for full setup guide.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── Optional ─ CAPTCHA (Cloudflare Turnstile) ────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Required (production) ─ Error Monitoring (Sentry) ────
SENTRY_DSN=
# Client-side Sentry DSN (enables browser error reporting via sentry.client.config.ts)
NEXT_PUBLIC_SENTRY_DSN=

# ── Optional ─ Cloudflare API (cache purge, deploy) ──────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=

# ── Cloudflare bindings (set via wrangler.jsonc / Cloudflare dashboard) ──
# RATE_LIMIT_KV — KV namespace for distributed rate limiting.
# Not a traditional env var; bind in wrangler.jsonc under [kv_namespaces].
# Required in production — without it, rate-limited routes reject all requests.
# See lib/rate-limit.ts for setup instructions.

# ── Optional ─ AI Content Engine ────────────────────────
# Fallback chain: Cloudflare AI → Gemini → Groq → Cohere
# A provider is used only when BOTH its credentials are present AND its
# AI_ENABLE_* flag is explicitly set to "true" (or "1"). Just having the
# API key is not enough — this lets you temporarily disable a provider
# without unsetting its key.
CLOUDFLARE_AI_API_TOKEN=
GEMINI_API_KEY=
GROQ_API_KEY=
COHERE_API_KEY=
AI_ENABLE_CLOUDFLARE=false
AI_ENABLE_GEMINI=false
AI_ENABLE_GROQ=false
AI_ENABLE_COHERE=false

# ── Optional ─ Affiliate Networks ──────────────────────
CJ_API_KEY=
CJ_PUBLISHER_ID=
PARTNERSTACK_API_KEY=
ADMITAD_API_KEY=
ADMITAD_PUBLISHER_ID=

# ── Optional ─ Multi-site development ────────────────────
# Controls which site localhost resolves to (e.g. watch-tools, crypto-tools, ai-compared)
NEXT_PUBLIC_DEFAULT_SITE=

# ── Required (multi-tenant) ─ Wildcard domain routing ───
# Comma-separated list of parent domains whose subdomains are resolved via DB.
# Defaults to "wristnerd.xyz" if not set.
# Example: WILDCARD_PARENT_DOMAINS=wristnerd.xyz,groupsmix.com
WILDCARD_PARENT_DOMAINS=

