# =============================================================================
# webs-alots — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Variables marked [Required] must be set for the app to start.
# Variables marked [Optional] enable additional features.
# =============================================================================

# ---- Supabase [Required] ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — used by rate limiter and cron jobs (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=

# ---- Site URL [Required] ----
# Used for SEO metadata, sitemap, robots.txt, and OpenGraph tags
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ---- Cloudflare Turnstile CAPTCHA [Required if Supabase captcha enabled] ----
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ---- Subdomain Routing [Optional] ----
# Set to your root domain (e.g., "yourdomain.com") to enable
# clinic subdomains like clinicname.yourdomain.com
# For local dev, subdomains work automatically via *.localhost
ROOT_DOMAIN=

# ---- Phone Auth Feature Flag [Required] ----
# Set to "true" only when Twilio SMS is fully configured and paid.
# When "false", phone/OTP login and registration are disabled in the UI
# and blocked server-side. Email+password login remains available.
NEXT_PUBLIC_PHONE_AUTH_ENABLED=false

# ---- Seed Password Rotation [Required in production] ----
# Migration 00019 creates seed users with a default password.
# After rotating all seed passwords in production, set this to "true".
# The server will hard-fail in production if not set to "true".
SEED_PASSWORDS_ROTATED=false

# ---- Booking Security [Required for public booking] ----
# HMAC secret for verifying OTP booking tokens.
# Generate with: openssl rand -hex 32
BOOKING_TOKEN_SECRET=

# ---- Cron Authentication [Required for cron jobs] ----
# Used by scheduled handlers to authenticate /api/cron/* routes.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ---- Cloudflare R2 Storage [Optional — file uploads] ----
# If not set, file upload endpoints return 503
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=webs-alots-uploads
R2_PUBLIC_URL=
# Disaster recovery replica bucket (different region)
R2_REPLICA_PUBLIC_URL=

# ---- WhatsApp Business API [Optional] ----
# Provider selection: "meta" (default) or "twilio"
WHATSAPP_PROVIDER=meta
# Meta Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
# Meta App Secret — required for verifying WhatsApp webhook signatures
META_APP_SECRET=

# ---- Twilio [Optional — required when WHATSAPP_PROVIDER=twilio] ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
TWILIO_SMS_FROM=

# ---- Stripe Payments [Optional] ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- CMI Payment Gateway [Optional — Morocco] ----
CMI_MERCHANT_ID=
CMI_SECRET_KEY=
CMI_GATEWAY_URL=

# ---- AI Chatbot — Smart level [Optional — Cloudflare Workers AI, free] ----
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_AI_API_TOKEN=

# ---- AI Chatbot — Advanced level [Optional — OpenAI-compatible, paid] ----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ---- Email [Optional — at least one provider needed for notifications] ----
# Resend (preferred)
RESEND_API_KEY=
# HTTP relay fallback (Mailgun / Postmark compatible — NOT raw SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@yourdomain.com

# ---- Google Calendar Sync [Optional] ----
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=

# ---- Custom Domains via Cloudflare [Optional] ----
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# ---- CORS for Public REST API [Optional] ----
# Comma-separated list of allowed origins for /api/v1/* endpoints.
# Leave empty to deny all cross-origin requests.
ALLOWED_API_ORIGINS=

# ---- Rate Limiting [Optional] ----
# Backend: "supabase" (distributed, default when credentials present) or "memory" (local)
RATE_LIMIT_BACKEND=

# ---- Database Backup [Optional] ----
SUPABASE_DB_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
