{
  "name": "health-saas",
  "version": "0.1.0",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/patch-opennext.mjs",
    "build:cf": "opennextjs-cloudflare build && node scripts/post-build-patch.mjs",
    "deploy": "npm run build:cf && wrangler deploy",
    "docs:generate": "typedoc",
    "analyze": "ANALYZE=true next build",
    "prepare": "husky",
    "backfill:patient-files": "tsx scripts/backfill-patient-files.ts",
    "audit:pii-logs": "tsx scripts/audit-pii-logs.ts",
    "evals:run": "tsx evals/run-evals.ts",
    "sbom:generate": "npx @cyclonedx/cdxgen --output-format JSON --output-file sbom.cdx.json",
    "licenses:check": "npx license-checker --onlyAllow 'MIT;ISC;Apache-2.0;BSD-2-Clause;BSD-3-Clause;CC0-1.0;Unlicense;Python-2.0;CC-BY-4.0' --excludePrivatePackages"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@aws-sdk/s3-presigned-post": "^3.1036.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@base-ui/react": "^1.4.1",
    "@sentry/nextjs": "^10.50.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.99.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "isomorphic-dompurify": "^3.3.0",
    "js-cookie": "^3.0.5",
    "lru-cache": "^11.0.2",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.0.8",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.4",
    "@opennextjs/cloudflare": "^1.17.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^25",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/swagger-ui-react": "^5.18.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-i18next": "^6.1.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^9.1.7",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.0",
    "lint-staged": "^16.4.0",
    "swagger-ui-react": "5.32.5",
    "tailwindcss": "^4",
    "typedoc": "^0.28.18",
    "typescript": "^5",
    "vitest": "^4.1.5",
    "wrangler": "^4.85.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix --max-warnings=0"
    ]
  },
  "overrides": {
    "postcss": "^8.5.10",
    "@hono/node-server": "^1.19.13",
    "react-copy-to-clipboard": "^5.1.1"
  },
  "_overrides_rationale": {
    "postcss": "A2-04: Pin postcss to >=8.5.10 to fix CVE-2026-41305 (XSS via unescaped </style> in CSS stringify output when user-submitted CSS is parsed and re-stringified for embedding in HTML style tags, GHSA-qx2v-qp2m-jg93). OpenNext and tailwindcss transitively depend on older postcss versions; this override ensures the patched version is used across the entire dependency tree to prevent XSS attacks.",
    "@hono/node-server": "A2-04: Pin to >=1.19.13 to fix a body-parsing regression in Cloudflare Workers runtime. OpenNext's @opennextjs/cloudflare transitively depends on hono; this override prevents the broken version from being resolved and ensures request body parsing works correctly in production.",
    "react-copy-to-clipboard": "A2-04: Pin to latest (^5.1.1) to resolve a peer dependency conflict with React 19. The package's peerDependencies specify React ^16 || ^17 || ^18, but React 19 is API-compatible; this override allows npm to resolve the dependency without warnings."
  }
}
