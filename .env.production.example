# ============================================================
# Production Environment Variables
# ============================================================
# Copy this file and fill in real values before deploying.
# Secrets should be set via Cloudflare Workers secrets (wrangler secret put),
# NOT committed to the repository.
# ============================================================

# ---- REQUIRED (app will fail without these) ----

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — used ONLY by rate limiter and admin operations.
# Set via: wrangler secret put SUPABASE_SERVICE_ROLE_KEY
# SUPABASE_SERVICE_ROLE_KEY=

# Site URL — used for SEO metadata, sitemap, robots.txt, and OpenGraph tags
NEXT_PUBLIC_SITE_URL=https://oltigo.com

# Subdomain routing — root domain for clinic subdomains (e.g., clinicname.oltigo.com)
ROOT_DOMAIN=oltigo.com

# Cron Authentication — authenticates Cloudflare Worker scheduled calls to /api/cron/*
# Generate with: openssl rand -hex 32
# Set via: wrangler secret put CRON_SECRET
# CRON_SECRET=

# Profile-header HMAC — signs x-auth-profile-* headers from middleware to withAuth.
# MUST be a distinct value from CRON_SECRET (audit R-02): a leak of one
# must not allow forging cron auth or session headers via the other.
# Generate with: openssl rand -hex 32
# Set via: wrangler secret put PROFILE_HEADER_HMAC_KEY
# PROFILE_HEADER_HMAC_KEY=

# Booking Token Secret — HMAC-SHA256 key for signing OTP verification tokens
# Generate with: openssl rand -hex 32
# Set via: wrangler secret put BOOKING_TOKEN_SECRET
# BOOKING_TOKEN_SECRET=

# ---- STRONGLY RECOMMENDED ----

# PHI Encryption Key — AES-256-GCM key for encrypting patient health information
# Generate with: openssl rand -hex 32 (must be exactly 64 hex chars)
# Set via: wrangler secret put PHI_ENCRYPTION_KEY
# PHI_ENCRYPTION_KEY=

# Sentry Error Monitoring
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id
# Required for source-map uploads (CI only):
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# SENTRY_AUTH_TOKEN=your-auth-token

# ---- PAYMENT INTEGRATIONS ----

# Stripe — for online payments
# Set via: wrangler secret put STRIPE_SECRET_KEY
# Set via: wrangler secret put STRIPE_WEBHOOK_SECRET
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# CMI (Moroccan payment gateway)
# Set via: wrangler secret put CMI_MERCHANT_ID
# Set via: wrangler secret put CMI_SECRET_KEY
# CMI_MERCHANT_ID=
# CMI_SECRET_KEY=

# ---- MESSAGING INTEGRATIONS ----

# WhatsApp Business API (Meta Cloud API)
# Set via: wrangler secret put WHATSAPP_ACCESS_TOKEN
# Set via: wrangler secret put META_APP_SECRET
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_PROVIDER=meta
# WHATSAPP_ACCESS_TOKEN=
# META_APP_SECRET=

# Optional: Twilio (when WHATSAPP_PROVIDER=twilio)
# Set via: wrangler secret put TWILIO_AUTH_TOKEN
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=

# Optional: Resend (transactional email)
# Set via: wrangler secret put RESEND_API_KEY
# RESEND_API_KEY=

# ---- STORAGE ----

# Cloudflare R2 Storage (for image/document uploads)
R2_BUCKET_NAME=webs-alots-uploads
# Set via: wrangler secret put R2_ACCESS_KEY_ID
# Set via: wrangler secret put R2_SECRET_ACCESS_KEY
# Set via: wrangler secret put R2_SIGNED_URL_SECRET  (REQUIRED — server refuses to boot without it)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_PUBLIC_URL=https://uploads.oltigo.com
# R2_SIGNED_URL_SECRET= (openssl rand -hex 32; rotate per docs/SOP-SECRET-ROTATION.md §8)

# ---- AI FEATURES (optional) ----

# Cloudflare Workers AI (free tier)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_AI_API_TOKEN=

# OpenAI-compatible API (paid)
# Set via: wrangler secret put OPENAI_API_KEY
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ---- FEATURE FLAGS ----

# Phone Auth — enable only when SMS provider is fully configured
NEXT_PUBLIC_PHONE_AUTH_ENABLED=false

# Data Masking — "full" | "partial" | "none"
# Production default is "partial" so PHI is never accidentally exposed in the UI.
# Setting this to "none" in production is rejected at startup unless the operator
# explicitly opts in by also setting ALLOW_UNMASKED_PHI=true (see SECURITY.md).
NEXT_PUBLIC_DATA_MASKING=partial

# Escape hatch: allow NEXT_PUBLIC_DATA_MASKING=none in production. Only the
# Security Officer / DPO may set this, with documented business justification
# and a follow-up audit task. See SECURITY.md → "PHI Masking Defaults".
# ALLOW_UNMASKED_PHI=true

# Seed Password Rotation — set to "true" after rotating all seed passwords
SEED_PASSWORDS_ROTATED=true

# Rate Limiting Backend — set in wrangler.toml [vars], not here
# RATE_LIMIT_BACKEND=kv

# ---- ANALYTICS ----

# Plausible (root domain analytics)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=oltigo.com
# NEXT_PUBLIC_PLAUSIBLE_HOST=https://plausible.io

# Performance Monitoring (opt-in)
# NEXT_PUBLIC_ENABLE_PERF_MONITORING=false
