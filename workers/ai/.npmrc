; Suppresses a single known peer-dep conflict:
;   @copilotkit/runtime@^1.59.5 declares @anthropic-ai/sdk@^0.57 as peerOptional
;   but this Worker pins @anthropic-ai/sdk@^0.101 (matching the main app).
;   The API surface we use (AnthropicAdapter constructor) is wire-compatible.
;
; REVIEW ON EACH @copilotkit/runtime UPGRADE:
;   Run `npm ls @anthropic-ai/sdk` and verify no unexpected version conflict
;   has been silently suppressed. If a genuine incompatibility appears,
;   remove this flag and use the `overrides` block in package.json instead.
legacy-peer-deps=true
