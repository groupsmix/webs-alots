# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# Optional: CMI Payment Gateway
CMI_MERCHANT_ID=
CMI_SECRET_KEY=

# Optional: AI Chatbot (OpenAI-compatible API)
# If not set, chatbot uses built-in rule-based responses
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Subdomain routing
# Set to your root domain (e.g., "yourdomain.com") to enable
# clinic subdomains like clinicname.yourdomain.com
# For local dev, subdomains work automatically via *.localhost
ROOT_DOMAIN=

# Optional: Cloudflare R2 Storage (for image uploads)
# If not set, file upload endpoints return 503
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=webs-alots-uploads
R2_PUBLIC_URL=
