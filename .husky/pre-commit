# Abort the commit as soon as any check below fails. Without `set -e` the hook's
# exit status would be that of the LAST command only, so lint-staged / tsc
# failures would be silently ignored and the commit would still succeed.
set -e

npx lint-staged
NODE_OPTIONS="--max-old-space-size=6144" npx tsc --noEmit

# A206: Run gitleaks on staged changes to catch secrets before they reach CI.
# Requires gitleaks to be installed locally (brew install gitleaks / go install).
# If gitleaks is not installed, warn but do not block the commit — CI will
# still catch secrets via the gitleaks GitHub Action in the security job.
if command -v gitleaks > /dev/null 2>&1; then
  gitleaks protect --staged --verbose
else
  echo "warning: gitleaks is not installed locally — secrets will still be scanned in CI"
fi
